# Copy to .env and fill in (never commit .env)

# ThetaData Phase 4 — credentials file OUTSIDE the repo (recommended)
# Line 1: email, line 2: password
THETADATA_CREDENTIALS_FILE=C:\Users\ROG\.thetadata\creds.txt

# Or inline (less preferred):
# THETADATA_EMAIL=your-email@example.com
# THETADATA_PASSWORD=your-password

# Cloud deploy (Railway / Render / Docker) — see docs/DEPLOY.md
# TERMINAL_HISTORY_DAYS=14
# TERMINAL_AUTH_USER=admin
# TERMINAL_AUTH_PASSWORD=choose-a-strong-password
# PORT=8765
